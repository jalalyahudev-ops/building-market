{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "maxLength": 100 },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "createdAt"]
    },
    "Store": {
      "title": "Store Profile",
      "description": "Store information",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string", "maxLength": 100 },
        "description": { "type": "string", "maxLength": 1000 },
        "address": { "type": "string", "maxLength": 300 },
        "phone": { "type": "string", "maxLength": 50 },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rating": { "type": "number", "minimum": 0, "maximum": 5 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "A product offered by a store",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "name": { "type": "string", "maxLength": 200 },
        "description": { "type": "string", "maxLength": 2000 },
        "category": { "type": "string", "maxLength": 100 },
        "price": { "type": "number", "minimum": 0 },
        "stock": { "type": "number", "minimum": 0 },
        "imageUrls": { "type": "array", "items": { "type": "string", "maxLength": 500 }, "maxItems": 10 },
        "rating": { "type": "number", "minimum": 0, "maximum": 5 },
        "status": { "type": "string", "enum": ["active", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "name", "category", "price", "stock", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a buyer to a store",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "storeId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "storeId", "totalAmount", "status"]
    },
    "Favorite": {
      "title": "User Favorite Product",
      "description": "A product favorited by a user",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a product or store",
      "type": "object",
      "properties": {
        "targetId": { "type": "string" },
        "type": { "type": "string", "enum": ["store", "product"] },
        "authorId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "text": { "type": "string", "maxLength": 1000 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["targetId", "type", "authorId", "rating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/stores/{storeId}": {
      "schema": { "$ref": "#/entities/Store" },
      "description": "Registered stores"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products offered by stores"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": { "$ref": "#/entities/Favorite" },
      "description": "User's favorite products"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Platform reviews"
    }
  }
}
